---
export function getStaticPaths() {
  const posts = {
    "rag-pipeline-chemical-patents": {
      title: "Building a production RAG pipeline for chemical patents",
      date: "Jun 2025",
      readTime: "8 min",
      tags: ["RAG", "LangChain", "Milvus"],
      content: `<p>Your post content here.</p>`,
    },
    "event-driven-biosensor": {
      title: "Event-driven architecture for biosensor data",
      date: "May 2025",
      readTime: "6 min",
      tags: ["Architecture", "CQRS"],
      content: `<p>Your content here.</p>`,
    },
    "nuxt3-session-bug": {
      title: "Nuxt 3 session management: the double-login bug",
      date: "Apr 2025",
      readTime: "5 min",
      tags: ["Nuxt 3", "Pinia", "Debugging"],
      content: `<p>Your content here.</p>`,
    },
  };

  return Object.entries(posts).map(([slug, data]) => ({
    params: { slug },
    props: { post: data },
  }));
}

const { post } = Astro.props;

if (!post) return Astro.redirect("/");
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.title} — Yogeesh</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <main class="post-page">
      <a href="/#blog" class="back mono">← back</a>
      <div class="post-meta mono">
        <span class="accent">{post.date}</span>
        <span>·</span>
        <span>{post.readTime} read</span>
      </div>
      <h1>{post.title}</h1>
      <div class="tags">
        {post.tags.map((t) => <span class="tag mono">{t}</span>)}
      </div>
      <div class="content" set:html={post.content} />
    </main>
  </body>
</html>

<style>
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
  }
  .post-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 80px 24px;
  }
  .back {
    font-size: 13px;
    color: var(--text-muted);
    display: block;
    margin-bottom: 48px;
    transition: color 0.15s;
  }
  .back:hover {
    color: var(--accent);
  }
  .post-meta {
    font-size: 13px;
    color: var(--text-muted);
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }
  h1 {
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .tags {
    display: flex;
    gap: 8px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 11px;
    padding: 4px 10px;
    border: 1px solid var(--border-strong);
    border-radius: 3px;
    color: var(--text-muted);
  }
  .content {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.8;
  }
  .content p {
    margin-bottom: 20px;
  }
  .content h2 {
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
    margin: 40px 0 16px;
  }
  .content code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg-2);
    padding: 2px 6px;
    border-radius: 3px;
  }
  .content pre {
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 6px;
    overflow-x: auto;
    margin: 24px 0;
  }
</style>
